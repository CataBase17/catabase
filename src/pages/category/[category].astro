---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { CATEGORIES } from '../../lib/categories';

const SUBCATEGORIES: Record<string, { slug: string; label: string; emoji: string }[]> = {
  'new-owner-basics': [
    { slug: 'getting-started',  label: 'Getting Started',  emoji: '🐾' },
    { slug: 'cat-life-stages',  label: 'Cat Life Stages',  emoji: '🐣' },
    { slug: 'home-and-safety',  label: 'Home & Safety',    emoji: '🏠' },
  ],
};

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return CATEGORIES.map(cat => ({
    params: { category: cat.slug },
    props: {
      cat,
      articles: articles
        .filter(a => a.data.category === cat.slug)
        .sort((a, b) => a.data.title.localeCompare(b.data.title)),
    },
  }));
}

const { cat, articles } = Astro.props;
const subcats = SUBCATEGORIES[cat.slug];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title={cat.label}>
  <style>
    .page-header { margin-bottom: 2rem; }
    .breadcrumb {
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-bottom: 0.75rem;
    }
    .breadcrumb a { color: var(--brand-dark); }
    .breadcrumb a:hover { text-decoration: underline; }
    h1 {
      font-size: clamp(1.6rem, 4vw, 2.2rem);
      font-weight: 700;
      letter-spacing: -0.02em;
    }
    .count { color: var(--text-muted); font-size: 1rem; font-weight: 400; }

    .article-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .article-list a {
      display: block;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 0.9rem 1.1rem;
      font-weight: 500;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .article-list a:hover {
      border-color: var(--brand);
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }

    /* Accordion */
    details {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 0.6rem;
      background: var(--surface);
      overflow: hidden;
    }
    details[open] { border-color: var(--brand); }
    summary {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 1rem 1.1rem;
      font-weight: 600;
      font-size: 1rem;
      cursor: pointer;
      list-style: none;
      user-select: none;
    }
    summary::-webkit-details-marker { display: none; }
    .summary-chevron {
      margin-left: auto;
      font-size: 0.75rem;
      color: var(--text-muted);
      transition: transform 0.2s;
    }
    details[open] .summary-chevron { transform: rotate(180deg); }
    .summary-count {
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--text-muted);
    }
    .accordion-body {
      padding: 0 0.75rem 0.75rem;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
  </style>

  <div class="page-header">
    <nav class="breadcrumb"><a href={`${base}/`}>Home</a> → {cat.label}</nav>
    <h1>{cat.emoji} {cat.label} <span class="count">({articles.length} articles)</span></h1>
  </div>

  {subcats ? (
    subcats.map(sub => {
      const group = articles.filter(a => a.data.subcategory === sub.slug);
      return group.length > 0 && (
        <details>
          <summary>
            <span>{sub.emoji} {sub.label}</span>
            <span class="summary-count">{group.length} articles</span>
            <span class="summary-chevron">▼</span>
          </summary>
          <div class="accordion-body">
            {group.map(a => (
              <a href={`${base}/articles/${a.data.slug}`}>{a.data.title}</a>
            ))}
          </div>
        </details>
      );
    })
  ) : (
    <ul class="article-list">
      {articles.map(a => (
        <li><a href={`${base}/articles/${a.data.slug}`}>{a.data.title}</a></li>
      ))}
    </ul>
  )}
</Base>
