---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "A friendly cat care guide for new cat owners." } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title === "Catabase" ? "Catabase" : `${title} — Catabase`}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --brand: #e8a838;
      --brand-dark: #c8891a;
      --bg: #fdfaf5;
      --surface: #ffffff;
      --border: #ede8df;
      --text: #2d2a25;
      --text-muted: #7a7268;
      --radius: 12px;
      --max-w: 860px;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      min-height: 100dvh;
    }

    a { color: inherit; text-decoration: none; }

    /* ── Header ── */
    header {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 0 1rem;
    }
    .header-inner {
      max-width: var(--max-w);
      margin: 0 auto;
      display: flex;
      align-items: center;
      gap: 1rem;
      height: 56px;
    }
    .logo {
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--brand-dark);
      letter-spacing: -0.02em;
    }
    .logo span { color: var(--text-muted); font-weight: 400; }

    /* ── Main ── */
    main {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 2rem 1rem 4rem;
    }

    /* ── Footer ── */
    footer {
      text-align: center;
      padding: 2rem 1rem;
      color: var(--text-muted);
      font-size: 0.85rem;
      border-top: 1px solid var(--border);
    }
  </style>
</head>
<body>
  <header>
    <div class="header-inner">
      <a href="/" class="logo">🐱 Catabase <span>cat care for humans</span></a>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    Built with love for a new cat owner. Based on Jackson Galaxy's advice.
  </footer>
</body>
</html>
